#include<stdio.h>

int main()
{
    int bt[] = {10, 5, 8}, wt[3] = {0}, tat[3], i;
    int total_wt = 0, total_tat = 0, n = 3;

    for(i = 1; i < n; i++)
        wt[i] = wt[i-1] + bt[i-1];

    for(i = 0; i < n; i++)
    {
        tat[i] = bt[i] + wt[i];
        total_wt += wt[i];
        total_tat += tat[i];

        printf("P%d  BT=%d  WT=%d  TAT=%d\n", i+1, bt[i], wt[i], tat[i]);
    }

    printf("Avg WT = %.2f\n", (float)total_wt/n);
    printf("Avg TAT = %.2f", (float)total_tat/n);

    return 0;
}
